# ============================================================
# Identificador do projeto (deriva queue, redis prefix, webhook path)
# ============================================================
PROJECT_SLUG=meuprojeto

# ============================================================
# Dados do negocio
# ============================================================
BUSINESS_NAME=Minha Empresa
ASSISTANT_NAME=Assistente

# ============================================================
# RabbitMQ (infra compartilhada - nao precisa mudar)
# ============================================================
RABBITMQ_HOST=91.98.64.92
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=default
# RABBITMQ_QUEUE=  # deixe vazio para usar PROJECT_SLUG

# ============================================================
# Redis (infra compartilhada - nao precisa mudar)
# ============================================================
REDIS_HOST=91.98.64.92
REDIS_PORT=6380
REDIS_PASSWORD=sua_senha_redis_aqui

# ============================================================
# Google Gemini
# ============================================================
GEMINI_API_KEY=sua_api_key_aqui

# ============================================================
# UAZAPI (WhatsApp)
# ============================================================
UAZAPI_BASE_URL=https://strategicai.uazapi.com
UAZAPI_TOKEN=seu_token_aqui
# UAZAPI_INSTANCE=  # deixe vazio para usar PROJECT_SLUG

# ============================================================
# Google Sheets
# ============================================================
GOOGLE_CREDENTIALS_JSON={"type":"service_account","...":"..."}
GOOGLE_SHEET_ID=id_da_planilha

# ============================================================
# App
# ============================================================
# WEBHOOK_PATH=  # deixe vazio para usar /PROJECT_SLUG
DEBOUNCE_SECONDS=30
BLOCK_TTL_SECONDS=3600

# ============================================================
# Alerta de atendimento humano
# ============================================================
ALERT_PHONE=5511999990000

# Numeros que ignoram debounce (comma-separated)
DEBOUNCE_BYPASS_PHONES=5511999990000

# Whitelist de numeros que a IA pode responder (comma-separated).
# Se vazio, responde para todos. Util em homologacao/piloto.
ALLOWED_PHONES=
